---
// KUEDocument.astro - Scientific Document Layout for kueper.com
import { getEntry } from 'astro:content';

const { slug } = Astro.props;
const entry = await getEntry('kue', slug);

if (!entry) {
  return Astro.redirect('/404');
}

const { Content } = await entry.render();
const { datum, titel, kategorie, marker, version, status, sprache } = entry.data;

// Format date
const formattedDate = new Date(datum).toLocaleDateString('de-DE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Category labels
const categoryLabels = {
  BIO: 'Biographical Profile',
  SCI: 'Scientific Framework',
  TEC: 'Technical Specification',
  LSC: 'Life Sciences',
  OBS: 'Observation',
  FND: 'Foundational',
  PHY: 'Physics',
  ARC: 'Architecture',
  HIS: 'History'
};

const categoryLabel = categoryLabels[kategorie] || kategorie;
---

<!DOCTYPE html>
<html lang={sprache.toLowerCase()}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{titel} | KUEPER.COM ARCHIV</title>
  <meta name="description" content={`${categoryLabel}: ${titel}`}>
  <link rel="stylesheet" href="/styles/fonts.css">
  <link rel="stylesheet" href="/styles/kue-document.css">
  <link rel="stylesheet" href="/styles/kue-print.css" media="print">
</head>
<body>

  <!-- Header Navigation -->
  <header class="doc-nav">
    <div class="nav-content">
      <a href="/" class="nav-brand">
        <svg class="nav-logo" viewBox="0 0 30 30" width="24" height="24">
          <rect x="4" y="4" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" transform="rotate(45 15 15)"/>
          <circle cx="15" cy="15" r="2" fill="currentColor"/>
        </svg>
        <span>KUEPER.COM</span>
      </a>
      <button class="print-btn" onclick="window.print()">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 9V2h12v7M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/>
          <rect x="6" y="14" width="12" height="8"/>
        </svg>
        <span>Als PDF speichern</span>
      </button>
    </div>
  </header>

  <!-- Document Container -->
  <main class="doc-container">
    
    <!-- Document Header -->
    <header class="doc-header">
      <div class="doc-logo">
        <svg viewBox="0 0 50 50" width="48" height="48">
          <rect x="8" y="8" width="34" height="34" fill="none" stroke="currentColor" stroke-width="2" transform="rotate(45 25 25)"/>
          <circle cx="25" cy="25" r="3" fill="currentColor"/>
        </svg>
      </div>
      
      <div class="doc-category">{categoryLabel}</div>
      <h1 class="doc-title">{titel}</h1>
      <div class="doc-signature">{slug}</div>
    </header>

    <!-- Metadata Box -->
    <section class="doc-meta">
      <div class="meta-grid">
        <div class="meta-item">
          <span class="meta-label">Signatur</span>
          <span class="meta-value"><code>{slug}</code></span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Kategorie</span>
          <span class="meta-value">{kategorie} — {categoryLabel}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Epistemische Marker</span>
          <span class="meta-value meta-markers">
            {marker.map(m => (
              <span class={`marker marker-${m.toLowerCase().replace(/[\[\]]/g, '')}`}>{m}</span>
            ))}
          </span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Version</span>
          <span class="meta-value">{version}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Status</span>
          <span class="meta-value">{status}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Datum</span>
          <span class="meta-value">{formattedDate}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Sprache</span>
          <span class="meta-value">{sprache}</span>
        </div>
      </div>
    </section>

    <!-- Document Content -->
    <article class="doc-content">
      <Content />
    </article>

    <!-- Document Footer -->
    <footer class="doc-footer">
      <div class="footer-sig">
        <svg viewBox="0 0 30 30" width="20" height="20">
          <rect x="4" y="4" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" transform="rotate(45 15 15)"/>
          <circle cx="15" cy="15" r="2" fill="currentColor"/>
        </svg>
        <span>{slug} · Version {version} · {formattedDate}</span>
      </div>
      <div class="footer-text">
        KUEPER.COM ARCHIV · Wissenschaftliche Wissensbasis
      </div>
    </footer>

  </main>

</body>
</html>
