---
// src/pages/kue/[kategorie].astro
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allDocs = await getCollection('kue');
  
  // Get unique categories
  const categories = [...new Set(allDocs.map(doc => doc.data.kategorie))];
  
  return categories.map(kategorie => ({
    params: { kategorie: kategorie.toLowerCase() },
    props: { kategorie }
  }));
}

const { kategorie } = Astro.props;
const allDocs = await getCollection('kue');
const docs = allDocs
  .filter(doc => doc.data.kategorie === kategorie)
  .sort((a, b) => new Date(b.data.datum).getTime() - new Date(a.data.datum).getTime());

// Category metadata
const categoryMeta: Record<string, { name: string; desc: string }> = {
  BIO: { name: 'Biographical Profiles', desc: 'Biografien realer historischer Personen' },
  SCI: { name: 'Scientific Frameworks', desc: 'Physikalische Theorien und wissenschaftliche Modelle' },
  TEC: { name: 'Technical Specifications', desc: 'Engineering und technische Spezifikationen' },
  LSC: { name: 'Life Sciences', desc: 'Neurologie, Genetik, Biologie, Medizin' },
  PHY: { name: 'Physics', desc: 'Quantenmechanik und fundamentale Kräfte' },
  ARC: { name: 'Architecture', desc: 'Konstruktionsprinzipien und Lebensraumgestaltung' },
  HIS: { name: 'History', desc: 'Wissenschaftlich recherchierte Geschichte' },
  GEO: { name: 'Geography', desc: 'Planetologie, Geologie, Terraforming' },
  PSY: { name: 'Psychology', desc: 'Sozialpsychologie und Verhaltensforschung' },
  SOC: { name: 'Sociology', desc: 'Organisationstheorie und Gruppenverhalten' },
  LNG: { name: 'Linguistics', desc: 'Sprachentwicklung und linguistische Systeme' },
  ECO: { name: 'Ecology', desc: 'Ökosysteme und Klimamodelle' },
  ORG: { name: 'Organizational Models', desc: 'Wissenschaftlich fundierte Strukturen' },
  OBS: { name: 'Observations', desc: 'Beobachtungs-Notizen und Einzelbefunde' },
  FND: { name: 'Foundational', desc: 'Methodendokumente der Plattform' },
  OPS: { name: 'Operations', desc: 'Operative Dokumente' },
  MET: { name: 'Methodology', desc: 'Methodologische Grundlagen' }
};

const meta = categoryMeta[kategorie] || { name: kategorie, desc: '' };
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{kategorie} — {meta.name} | KUEPER.COM ARCHIV</title>
  <meta name="description" content={meta.desc}>
  <link rel="stylesheet" href="/styles/fonts.css">
  <link rel="stylesheet" href="/styles/kue-document.css">
  <style>
    .category-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }
    
    .category-nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--kue-border);
    }
    
    .back-link {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      color: #666;
      text-decoration: none;
      font-size: 0.95rem;
      transition: color 0.2s;
    }
    
    .back-link:hover {
      color: var(--kue-fg);
    }
    
    .category-header {
      margin-bottom: 3rem;
    }
    
    .category-id {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.9rem;
      font-weight: 600;
      color: #666;
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
    }
    
    .category-title {
      font-family: 'Inter', sans-serif;
      font-size: 2.5rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      color: var(--kue-fg);
      margin: 0 0 0.75rem 0;
    }
    
    .category-desc {
      font-family: 'Source Serif Pro', serif;
      font-size: 1.1rem;
      line-height: 1.6;
      color: #666;
      max-width: 700px;
    }
    
    .doc-count {
      font-size: 0.95rem;
      color: #888;
      margin-top: 1rem;
    }
    
    .doc-list {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    
    .doc-item {
      background: white;
      border: 1px solid var(--kue-border);
      border-radius: 6px;
      padding: 1.5rem;
      transition: all 0.2s ease;
      text-decoration: none;
      color: inherit;
      display: block;
    }
    
    .doc-item:hover {
      border-color: #999;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      transform: translateY(-2px);
    }
    
    .doc-meta-line {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 0.75rem;
      font-size: 0.85rem;
    }
    
    .doc-signature {
      font-family: 'JetBrains Mono', monospace;
      font-weight: 600;
      color: #666;
    }
    
    .doc-date {
      color: #999;
    }
    
    .doc-markers {
      display: flex;
      gap: 0.25rem;
      margin-left: auto;
    }
    
    .marker {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      font-weight: 600;
      padding: 0.15rem 0.4rem;
      border-radius: 3px;
      letter-spacing: 0.02em;
    }
    
    .marker-r { background: #e8f5e9; color: var(--marker-r); }
    .marker-t { background: #e3f2fd; color: var(--marker-t); }
    .marker-s { background: #f3e5f5; color: var(--marker-s); }
    .marker-p { background: #e0f2f1; color: var(--marker-p); }
    .marker-h { background: #fff3e0; color: var(--marker-h); }
    
    .doc-title {
      font-family: 'Inter', sans-serif;
      font-size: 1.3rem;
      font-weight: 600;
      color: var(--kue-fg);
      margin: 0 0 0.5rem 0;
      line-height: 1.3;
    }
    
    .doc-abstract {
      font-family: 'Source Serif Pro', serif;
      font-size: 0.95rem;
      line-height: 1.6;
      color: #666;
      margin: 0;
    }
    
    .category-footer {
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid var(--kue-border);
      text-align: center;
      color: #888;
      font-size: 0.9rem;
    }
    
    @media (max-width: 768px) {
      .category-title {
        font-size: 2rem;
      }
      
      .doc-meta-line {
        flex-wrap: wrap;
      }
      
      .doc-markers {
        margin-left: 0;
        width: 100%;
      }
    }
  </style>
</head>
<body>
  
  <div class="category-container">
    
    <!-- Navigation -->
    <nav class="category-nav">
      <a href="/kue" class="back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M10 12L6 8l4-4"/>
        </svg>
        Zurück zur Übersicht
      </a>
      <div style="font-size: 0.9rem; color: #999;">
        {docs.length} {docs.length === 1 ? 'Dokument' : 'Dokumente'}
      </div>
    </nav>
    
    <!-- Category Header -->
    <header class="category-header">
      <div class="category-id">{kategorie}</div>
      <h1 class="category-title">{meta.name}</h1>
      <p class="category-desc">{meta.desc}</p>
    </header>
    
    <!-- Document List -->
    {docs.length > 0 ? (
      <div class="doc-list">
        {docs.map(doc => {
          const date = new Date(doc.data.datum);
          const formattedDate = date.toLocaleDateString('de-DE', { 
            year: 'numeric', 
            month: 'long', 
            day: 'numeric' 
          });
          
          return (
            <a href={`/kue/${doc.slug}`} class="doc-item">
              <div class="doc-meta-line">
                <span class="doc-signature">{doc.slug.toUpperCase()}</span>
                <span class="doc-date">{formattedDate}</span>
                <div class="doc-markers">
                  {doc.data.marker.map((m: string) => (
                    <span class={`marker marker-${m.toLowerCase().replace(/[\[\]]/g, '')}`}>
                      {m}
                    </span>
                  ))}
                </div>
              </div>
              <h2 class="doc-title">{doc.data.titel}</h2>
            </a>
          );
        })}
      </div>
    ) : (
      <div style="text-align: center; padding: 3rem; color: #999;">
        Noch keine Dokumente in dieser Kategorie.
      </div>
    )}
    
    <!-- Footer -->
    <footer class="category-footer">
      <svg viewBox="0 0 30 30" width="20" height="20" style="vertical-align: middle; margin-right: 8px;">
        <rect x="4" y="4" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" transform="rotate(45 15 15)"/>
        <circle cx="15" cy="15" r="2" fill="currentColor"/>
      </svg>
      KUEPER.COM ARCHIV
    </footer>
    
  </div>

</body>
</html>
