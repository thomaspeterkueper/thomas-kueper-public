---
const currentPath = Astro.url.pathname;

const isActive = (path: string) => {
  if (path === '/' && currentPath === '/') return true;
  if (path !== '/' && currentPath.startsWith(path)) return true;
  return false;
};
---

<nav class="main-nav">
  <div class="nav-container">
    <!-- Logo & Title -->
    <a href="/" class="nav-brand">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="8" y="8" width="8" height="8" transform="rotate(45 12 12)" stroke="currentColor" stroke-width="1.5"/>
        <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
      </svg>
      <span class="nav-title">KUEPER.COM</span>
    </a>

    <!-- Main Menu -->
    <div class="nav-menu">
      <a href="/" class={isActive('/') ? 'nav-link active' : 'nav-link'}>
        Start
      </a>
      
      <a href="/kue" class={isActive('/kue') ? 'nav-link active' : 'nav-link'}>
        Archiv
      </a>
      
      <a href="/ueber" class={isActive('/ueber') ? 'nav-link active' : 'nav-link'}>
        Über das Archiv
      </a>
      
      <a href="/dokumentenklassen" class={isActive('/dokumentenklassen') ? 'nav-link active' : 'nav-link'}>
        Dokumentenklassen
      </a>
    </div>

    <!-- Language Switcher -->
    <div class="nav-lang">
      <button class="lang-btn active" aria-label="Deutsch">DE</button>
      <span class="lang-separator">/</span>
      <button class="lang-btn" aria-label="English" disabled>EN</button>
    </div>
  </div>
</nav>

<style>
.main-nav {
  position: sticky;
  top: 0;
  z-index: 1000;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid #e0e0e0;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.nav-container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 2rem;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
}

/* Brand */
.nav-brand {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  text-decoration: none;
  color: #1a1a1a;
  font-weight: 600;
  font-size: 0.95rem;
  letter-spacing: 0.03em;
  transition: opacity 0.2s;
}

.nav-brand:hover {
  opacity: 0.7;
}

.nav-brand svg {
  flex-shrink: 0;
}

.nav-title {
  font-family: 'JetBrains Mono', monospace;
}

/* Menu */
.nav-menu {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex: 1;
  justify-content: center;
}

.nav-link {
  padding: 0.5rem 1rem;
  text-decoration: none;
  color: #4a4a4a;
  font-size: 0.9rem;
  font-weight: 500;
  border-radius: 6px;
  transition: all 0.2s;
  position: relative;
}

.nav-link:hover {
  color: #1a1a1a;
  background: #f5f5f5;
}

.nav-link.active {
  color: #1a1a1a;
  background: #f0f0f0;
}

.nav-link.active::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 1rem;
  right: 1rem;
  height: 2px;
  background: #1a1a1a;
}

/* Language Switcher */
.nav-lang {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.85rem;
  font-family: 'JetBrains Mono', monospace;
  color: #666;
}

.lang-btn {
  background: none;
  border: none;
  padding: 0.35rem 0.5rem;
  cursor: pointer;
  font-family: inherit;
  font-size: inherit;
  color: #999;
  border-radius: 4px;
  transition: all 0.2s;
}

.lang-btn:hover:not(:disabled) {
  color: #1a1a1a;
  background: #f5f5f5;
}

.lang-btn.active {
  color: #1a1a1a;
  font-weight: 600;
}

.lang-btn:disabled {
  cursor: not-allowed;
  opacity: 0.4;
}

.lang-separator {
  color: #ddd;
  user-select: none;
}

/* Responsive */
@media (max-width: 768px) {
  .nav-container {
    padding: 0 1rem;
  }
  
  .nav-menu {
    gap: 0.25rem;
  }
  
  .nav-link {
    padding: 0.5rem 0.75rem;
    font-size: 0.85rem;
  }
  
  .nav-title {
    display: none;
  }
}

@media (max-width: 600px) {
  .nav-menu {
    display: none;
  }
  
  /* Mobile menu would go here - hamburger etc. */
}
</style>
